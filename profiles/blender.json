{
  "id": "blender",
  "displayName": "Blender",
  "enabled": false,
  "processNames": ["blender"],
  "isDefault": false,
  "functions": [
    {
      "id": "timeline",
      "label": "Timeline",
      "iconName": "media-seek-forward",
      "type": "discrete",
      "clockwiseAction": {
        "type": "keyboard",
        "keys": "right",
        "rotationThreshold": 3
      },
      "counterClockwiseAction": {
        "type": "keyboard",
        "keys": "left",
        "rotationThreshold": 3
      },
      "clickAction": {
        "type": "keyboard",
        "keys": "space"
      }
    },
    {
      "id": "undo-redo",
      "label": "Undo / Redo",
      "iconName": "edit-undo",
      "type": "discrete",
      "clockwiseAction": {
        "type": "keyboard",
        "keys": "z",
        "modifiers": ["ctrl", "shift"],
        "rotationThreshold": 5
      },
      "counterClockwiseAction": {
        "type": "keyboard",
        "keys": "z",
        "modifiers": ["ctrl"],
        "rotationThreshold": 5
      }
    },
    {
      "id": "zoom",
      "label": "Zoom",
      "iconName": "zoom-in",
      "type": "discrete",
      "clockwiseAction": {
        "type": "keyboard",
        "keys": "ZoomIn",
        "rotationThreshold": 5
      },
      "counterClockwiseAction": {
        "type": "keyboard",
        "keys": "ZoomOut",
        "rotationThreshold": 5
      }
    },
    {
      "id": "scroll",
      "label": "Scroll",
      "iconName": "view-scroll-vertical",
      "type": "discrete",
      "clockwiseAction": {
        "type": "mouseScroll",
        "delta": -3,
        "rotationThreshold": 3
      },
      "counterClockwiseAction": {
        "type": "mouseScroll",
        "delta": 3,
        "rotationThreshold": 3
      }
    }
  ],
  "defaultMenuLayout": ["timeline", "undo-redo", "zoom", "scroll"]
}
