{
  "id": "krita",
  "displayName": "Krita",
  "enabled": false,
  "processNames": ["krita"],
  "isDefault": false,
  "functions": [
    {
      "id": "brush-size",
      "label": "Brush Size",
      "iconName": "draw-brush",
      "type": "continuous",
      "minValue": 0,
      "maxValue": 100,
      "unit": "%",
      "clockwiseAction": {
        "type": "keyboard",
        "keys": "bracketright",
        "rotationThreshold": 3
      },
      "counterClockwiseAction": {
        "type": "keyboard",
        "keys": "bracketleft",
        "rotationThreshold": 3
      }
    },
    {
      "id": "undo-redo",
      "label": "Undo / Redo",
      "iconName": "edit-undo",
      "type": "discrete",
      "clockwiseAction": {
        "type": "keyboard",
        "keys": "z",
        "modifiers": ["ctrl", "shift"],
        "rotationThreshold": 5
      },
      "counterClockwiseAction": {
        "type": "keyboard",
        "keys": "z",
        "modifiers": ["ctrl"],
        "rotationThreshold": 5
      }
    },
    {
      "id": "zoom",
      "label": "Zoom",
      "iconName": "zoom-in",
      "type": "discrete",
      "clockwiseAction": {
        "type": "keyboard",
        "keys": "ZoomIn",
        "rotationThreshold": 5
      },
      "counterClockwiseAction": {
        "type": "keyboard",
        "keys": "ZoomOut",
        "rotationThreshold": 5
      }
    },
    {
      "id": "scroll",
      "label": "Scroll",
      "iconName": "view-scroll-vertical",
      "type": "discrete",
      "clockwiseAction": {
        "type": "mouseScroll",
        "delta": -3,
        "rotationThreshold": 3
      },
      "counterClockwiseAction": {
        "type": "mouseScroll",
        "delta": 3,
        "rotationThreshold": 3
      }
    }
  ],
  "defaultMenuLayout": ["brush-size", "undo-redo", "zoom", "scroll"]
}
